{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "lib":            ["DOM", "DOM.Iterable", "ES2022"],
    "jsx":            "preserve",
    "plugins":        [{ "name": "next" }],
    "allowJs":        true,
    "noEmit":         true,
    "incremental":    true,
    "module":         "ESNext",
    "moduleResolution": "Bundler"
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next", "dist"]
}
