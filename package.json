{
  "name": "ppid-baznas-cianjur",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @ppid/db generate",
    "db:migrate":  "pnpm --filter @ppid/db migrate",
    "db:studio":   "pnpm --filter @ppid/db studio",
    "db:seed":     "pnpm --filter @ppid/db seed"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.31.4"
    }
  }
}
